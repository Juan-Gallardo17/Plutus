<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:text="Nombre de la deuda"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/et_nombre_deuda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: Préstamo mamá, Cuota celular"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:text="Monto ($)"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/et_monto_deuda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: 200000"
        android:inputType="numberDecimal"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:text="Fecha límite (opcional)"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/et_fecha_deuda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: 2026-05-15"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:text="Estado"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Spinner
        android:id="@+id/spinner_estado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>